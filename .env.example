# Copy this file to `.env` and fill in your credentials, then restart `npm run dev`.

# --- Supabase (for the mortgage_leads table) ---
# When omitted, lead submissions are simulated locally.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Google Maps ---
# NOTE: this key is bundled into the client and is publicly visible in the
# browser. You MUST restrict it in Google Cloud Console:
#   1. Application restrictions -> HTTP referrers, allow:
#        http://localhost:5173/*
#        https://<your-username>.github.io/<repo>/*
#   2. API restrictions -> only the APIs you use (e.g. Maps JavaScript API,
#      Places API).
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
